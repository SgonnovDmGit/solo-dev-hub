{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Solo Dev Hub",
  "version": "1.0.5",
  "identifier": "com.solodevhub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Solo Dev Hub",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SgonnovDmGit/solo-dev-hub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRENTgxMzNENjE0NzI5MUUKUldRZUtVZGhQUk5ZVFdtekw2TUpib29uSDRSRnFISERuVjNLOXNSRkVmN0N5WnpmR1pLdkgrc0IK"
    }
  }
}
