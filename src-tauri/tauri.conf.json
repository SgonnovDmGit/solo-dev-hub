{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "github-repo-manager",
  "version": "0.24.2",
  "identifier": "com.user2.github-repo-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "GitHub Repo Manager",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SgonnovDmGit/github-repo-manager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxMzVBOTdBM0MzRjg5RUYKUldUdmlUODhlcWsxY1VlakZiU2dlT1kwYkFmWkxZNUlvSG1GNFJlKzllaTh5aTNnT01acWpkK3AK"
    }
  }
}
