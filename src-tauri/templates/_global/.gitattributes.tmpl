# Нормализация строк (по global rules) — предотвращает autocrlf-фантомы на Windows
* text=auto eol=lf

# Исходники — явный text + LF
*.rs text eol=lf
*.go text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.svelte text eol=lf
*.vue text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.sql text eol=lf

# Windows-скрипты — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Бинарные ассеты — не трогаются нормализацией
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.exe binary
*.dll binary
