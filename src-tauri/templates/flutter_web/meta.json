{
  "display_name": "flutter_web",
  "description": "Flutter Web deploy: сборка Docker-образа и пуш в GHCR, деплой на VPS через SSH, настройка proxy-host в Nginx Proxy Manager с Let's Encrypt сертификатом.",
  "placeholders": {
    "WORKFLOW_NAME": { "label": { "ru": "Имя workflow", "en": "Workflow name" }, "description": { "ru": "Имя workflow в GitHub Actions", "en": "GitHub Actions workflow name" }, "default": "", "type": "string" },
    "IMAGE_TAG": { "label": { "ru": "Docker tag", "en": "Docker tag" }, "description": { "ru": "Тег образа (prod/test/latest)", "en": "Image tag (prod/test/latest)" }, "default": "prod", "type": "string" },
    "COMPOSE_SERVICE": { "label": { "ru": "Имя compose-сервиса", "en": "Compose service name" }, "description": { "ru": "Значение label com.docker.compose.service", "en": "Value for com.docker.compose.service label" }, "default": "", "type": "string" },
    "DOMAIN": { "label": { "ru": "Домен", "en": "Domain" }, "description": { "ru": "Публичный домен с A-записью на VPS", "en": "Public domain pointing to VPS" }, "default": "", "type": "string" },
    "DEPLOY_BRANCH": { "label": { "ru": "Ветка деплоя", "en": "Deploy branch" }, "description": { "ru": "Ветка, push в которую триггерит деплой", "en": "Branch that triggers deploy on push" }, "default": "master", "type": "string" },
    "NETWORK_NAME": { "label": { "ru": "Docker network", "en": "Docker network" }, "description": { "ru": "Имя docker-сети, к которой подключается контейнер. Разные env'ы могут использовать разные сети для изоляции.", "en": "Docker network name the container joins. Different envs may use different networks for isolation." }, "default": "", "type": "string" },
    "COMPOSE_PROJECT": { "label": { "ru": "Compose project label", "en": "Compose project label" }, "description": { "ru": "Значение label com.docker.compose.project. Обычно {service}_{env}.", "en": "Value for com.docker.compose.project label. Typically {service}_{env}." }, "default": "", "type": "string" }
  },
  "required_secrets": [
    { "name": "API_BASE_URL", "multiline": false, "description": "Публичный URL backend API", "role": "build", "scope": "environment" },
    { "name": "APP_API_KEY", "multiline": false, "description": "Ключ авторизации в API", "role": "build", "scope": "environment" },
    { "name": "SSH_HOST", "multiline": false, "description": "IP или домен VPS", "role": "deploy", "scope": "environment" },
    { "name": "SSH_USER", "multiline": false, "description": "SSH пользователь", "role": "deploy", "scope": "environment" },
    { "name": "SSH_KEY", "multiline": true, "description": "Приватный SSH ключ (OpenSSH PEM)", "role": "deploy", "scope": "environment" },
    { "name": "SSH_PORT", "multiline": false, "description": "SSH порт (обычно 22)", "role": "deploy", "scope": "environment" },
    { "name": "CONTAINER_NAME", "multiline": false, "description": "Имя docker-контейнера на VPS (forward_host в NPM). Уникально на env.", "role": "deploy", "scope": "environment" },
    { "name": "NPM_EMAIL", "multiline": false, "description": "Email API-пользователя NPM", "role": "deploy", "scope": "repo" },
    { "name": "NPM_PASSWORD", "multiline": false, "description": "Пароль API-пользователя NPM", "role": "deploy", "scope": "repo" }
  ],
  "file_targets": {
    "deploy.yml.tmpl": ".github/workflows/deploy-{name}.yml",
    "dockerfile.tmpl": "Dockerfile"
  },
  "version": 4
}
