# ---- Build stage ----
FROM golang:@@GO_VERSION@@-alpine AS builder

# git may be required by `go mod download` for private deps
RUN apk add --no-cache git

# Build-role secrets declared as ARGs so they're available during build steps
# (e.g. `-ldflags "-X main.ApiKey=$NAME"` or private-registry auth). The UNION
# across all envs of this repo is rendered here; per-env values come in via
# --build-arg from the workflow. Empty when no build-role secrets in scope.
@@DOCKERFILE_ARGS@@

# /src, not /app — the build directory name MUST differ from @@BINARY_NAME@@,
# otherwise `go build -o /<binary>` sees a directory and writes the binary inside it
# under the package name instead of as the intended filename.
WORKDIR /src

# Cache dependencies layer
COPY go.mod go.sum ./
RUN go mod download

# Copy source and build static binary
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/@@BINARY_NAME@@ @@ENTRY_POINT@@

# ---- Runtime stage ----
FROM debian:bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /out/@@BINARY_NAME@@ ./

# SQL migrations bundled into the image. If your project does NOT use embedded
# migrations (or you keep them outside /src/migrations), comment this line —
# COPY fails loudly if the source path doesn't exist.
COPY --from=builder /src/migrations ./migrations

EXPOSE @@APP_PORT@@

CMD ["./@@BINARY_NAME@@"]
