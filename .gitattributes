# Default: treat all text files with LF line endings.
# Prevents core.autocrlf=true from inserting phantom modifications on Windows.
* text=auto eol=lf

# Source code — explicit text + LF
*.rs       text eol=lf
*.toml     text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.svelte   text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.sh       text eol=lf
*.tmpl     text eol=lf
*.sql      text eol=lf

# Lock files — keep as text but normalized
Cargo.lock         text eol=lf
package-lock.json  text eol=lf

# Binary assets — never touched by text-normalization
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.zip   binary
*.exe   binary
*.dll   binary
